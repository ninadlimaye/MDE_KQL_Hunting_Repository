// Tactic: Hunting Utility
// Technique: N/A
// Severity: Medium
// Description: Finds unsigned binaries launched from common user-writable directories.

DeviceProcessEvents
| where Timestamp > ago(7d)
| where FolderPath has_any ("\Users\", "\ProgramData\", "\Temp\", "\AppData\")
| where SignatureStatus != "Signed"
| project Timestamp, DeviceName, InitiatingProcessAccountName,
          FileName, FolderPath, ProcessCommandLine, SHA256, SignatureStatus
