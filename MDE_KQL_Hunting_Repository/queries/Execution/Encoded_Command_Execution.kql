// Tactic: Execution
// Technique: T1059
// Severity: High
// Description: Detects encoded or obfuscated command-line usage.

DeviceProcessEvents
| where Timestamp > ago(7d)
| where ProcessCommandLine has_any ("-enc", "-encodedcommand", "/enc", "/encodedcommand", "FromBase64String")
| project Timestamp, DeviceName, InitiatingProcessAccountName,
          FileName, ProcessCommandLine, InitiatingProcessFileName,
          InitiatingProcessCommandLine
