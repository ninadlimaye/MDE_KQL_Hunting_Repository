// Tactic: Credential Access
// Technique: T1003.001 - LSASS Memory
// Severity: Critical
// Description: Detects common LSASS dump command-line artifacts.

DeviceProcessEvents
| where Timestamp > ago(7d)
| where ProcessCommandLine has_any (
    "lsass", "comsvcs.dll", "MiniDump", "procdump",
    "nanodump", "sekurlsa", "lsass.dmp"
)
| project Timestamp, DeviceName, InitiatingProcessAccountName,
          FileName, ProcessCommandLine, InitiatingProcessFileName, SHA256
