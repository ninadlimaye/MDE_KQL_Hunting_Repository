// Tactic: Credential Access
// Technique: T1003.003 - NTDS
// Severity: Critical
// Description: Detects commands commonly used to copy or dump NTDS.dit.

DeviceProcessEvents
| where Timestamp > ago(14d)
| where ProcessCommandLine has_any ("ntds.dit", "vssadmin", "diskshadow", "esentutl", "ntdsutil")
| project Timestamp, DeviceName, InitiatingProcessAccountName,
          FileName, ProcessCommandLine, InitiatingProcessFileName
