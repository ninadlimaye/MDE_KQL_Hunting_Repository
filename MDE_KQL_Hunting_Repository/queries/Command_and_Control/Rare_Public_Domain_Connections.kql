// Tactic: Command and Control
// Technique: T1071
// Severity: Medium
// Description: Finds domains contacted by few devices.

DeviceNetworkEvents
| where Timestamp > ago(7d)
| where isnotempty(RemoteUrl)
| where RemoteIPType == "Public"
| summarize Devices=dcount(DeviceName),
            Connections=count(),
            Examples=make_set(InitiatingProcessCommandLine, 5)
  by RemoteUrl
| where Devices <= 2 and Connections >= 3
| order by Devices asc, Connections desc
